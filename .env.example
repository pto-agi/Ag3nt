# Trainerize credentials
TRAINERIZE_EMAIL=your_email@example.com
TRAINERIZE_PASSWORD=your_password_here

# Gemini AI (for AI coaching features)
GEMINI_API_KEY=your_gemini_api_key_here

# Agent settings
LOG_LEVEL=info

# Supabase (for client data/forms)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Todoist (for task management)
TODOIST_API_KEY=your_todoist_api_key_here

# Optional: Google Sheets service account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----\n"